server {
    listen 80;
    server_name chengnanblog.cn;
    return 301 https://$host$request_uri;
}
server {
    listen 443 ssl http2;
    server_name chengnanblog.cn;
    ssl_certificate /etc/letsencrypt/live/chengnanblog.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chengnanblog.cn/privkey.pem;
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}
